  "query": "\n        UPDATE categories\n        SET \n            name = COALESCE($1, name),\n            color = COALESCE($2, color),\n            updated_at = CURRENT_TIMESTAMP\n        WHERE id = $3\n        RETURNING id, name, color, created_at, user_id\n        ",
